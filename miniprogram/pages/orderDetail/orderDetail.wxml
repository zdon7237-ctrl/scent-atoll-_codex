<view class="page">
  <view wx:if="{{isLoading}}" class="state-tip">订单加载中...</view>

  <view wx:elif="{{loadError}}" class="state-tip">{{loadError}}</view>

  <scroll-view wx:elif="{{order}}" scroll-y class="detail-scroll">
    <view class="status-band">
      <view class="status-text">{{order.statusText}}</view>
      <view class="status-sub">订单号 {{order.orderNo}}</view>
      <button class="copy-btn" bindtap="onCopyOrderNo">复制</button>
    </view>

    <view class="section">
      <view class="section-title">商品信息</view>
      <view class="goods-row" wx:for="{{order.items}}" wx:key="id">
        <image src="{{item.image}}" mode="aspectFill" class="goods-img"></image>
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-meta">{{item.brand}} x{{item.quantity}}</view>
        </view>
        <view class="goods-price">¥{{item.priceText}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">金额明细</view>
      <view class="info-row">
        <text>商品原价</text>
        <text>¥{{order.originalPriceText}}</text>
      </view>
      <view class="info-row">
        <text>会员价</text>
        <text>¥{{order.memberPriceText}}</text>
      </view>
      <view class="info-row">
        <text>优惠券</text>
        <text>-¥{{order.couponDiscountText}}</text>
      </view>
      <view class="info-row strong">
        <text>还需支付</text>
        <text>¥{{order.payAmountText}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">收货信息</view>
      <view class="plain-text">{{order.deliveryText || '暂无收货信息'}}</view>
      <view wx:if="{{order.deliveryNoteText}}" class="muted-text">备注：{{order.deliveryNoteText}}</view>
    </view>

    <view class="section">
      <view class="section-title">支付与物流</view>
      <view class="info-row">
        <text>支付状态</text>
        <text>{{order.paymentStatusText}}</text>
      </view>
      <view class="info-row">
        <text>物流状态</text>
        <text>{{order.shippingStatusText}}</text>
      </view>
      <view class="info-row">
        <text>下单时间</text>
        <text>{{order.createTimeText}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{order && order.status === 0}}" class="bottom-bar">
    <button class="pay-btn" bindtap="onPay" loading="{{isPaying}}" disabled="{{isPaying}}">去支付</button>
  </view>
</view>
