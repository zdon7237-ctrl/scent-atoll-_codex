<view class="container">
  <view class="fixed-header">
    <view class="header-row">
      <view class="back-btn" wx:if="{{searchQuery}}" bindtap="resetSearch">
        <text class="back-icon">←</text>
      </view>
      <view class="search-box">
        <view class="search-inner">
          <icon type="search" size="14" color="#999"></icon>
          <input 
            class="search-input"
            placeholder="请输入想要搜索的香水" 
            placeholder-class="ph-text"
            bindinput="onSearchInput" 
            value="{{searchQuery}}" 
            confirm-type="search"
          />
          <view class="clear-icon" wx:if="{{searchQuery}}" catchtap="resetSearch">×</view>
        </view>
      </view>
    </view>

    <view class="sort-bar">
      <view class="sort-item {{activeTab===0 ? 'active' : ''}}" bindtap="onTabClick" data-index="0">综合</view>
      <view class="sort-item {{activeTab===1 ? 'active' : ''}}" bindtap="onTabClick" data-index="1">销量</view>
      <view class="sort-item {{activeTab===2 ? 'active' : ''}}" bindtap="onTabClick" data-index="2">
        价格 <text class="arrow">{{activeTab===2 ? (sortAsc ? '↑' : '↓') : ''}}</text>
      </view>
      <view class="sort-item {{activeTab===3 ? 'active' : ''}}" bindtap="onTabClick" data-index="3">上新</view>
      <view class="sort-icon">∷</view> 
    </view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <view class="goods-grid">
      <block wx:if="{{perfumes.length > 0}}">
        <view class="goods-card" wx:for="{{perfumes}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <view class="img-wrapper">
            <image src="{{item.image}}" mode="aspectFill" class="goods-img"></image>
            <view wx:if="{{item.isNew}}" class="badge-new">NEW</view>
            <view wx:if="{{item.stock < 5}}" class="badge-stock">仅剩{{item.stock}}件</view>
          </view>
          
          <view class="content">
            <view class="title">{{item.name}}</view>
            <view class="tags-row">
              <text class="tag-member" wx:if="{{item.isMember}}">会员价</text>
              <text class="sold-num">已售 {{item.sales}}</text>
            </view>
            
            <view class="bottom-row">
              <view class="price-wrapper">
                <block wx:if="{{item.hasDiscount}}">
                  <view class="price-lowest">
                    <text class="tag-coupon">券后</text>
                    <text class="symbol">¥</text>
                    <text class="num">{{item.lowestPrice}}</text>
                  </view>
                  <view class="price-origin">{{item.isMember ? '会员' : '原价'}} ¥{{item.currentPrice}}</view>
                </block>

                <block wx:else>
                  <view class="price-current">
                    <text class="symbol">¥</text>
                    <text class="num">{{item.currentPrice}}</text>
                  </view>
                  <block wx:if="{{item.isMember}}">
                    <view class="price-origin">原价 ¥{{item.originalPrice}}</view>
                  </block>
                  <block wx:elif="{{item.canUseMemberPrice}}">
                    <view class="price-origin">加入会员享折扣</view>
                  </block>
                </block>
              </view>
              
              <view class="cart-btn" catchtap="addToCart" data-item="{{item}}">
                <text class="cart-icon">🛒</text> 
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-tip">没有找到相关香水</view>
    </view>
  </scroll-view>
</view>