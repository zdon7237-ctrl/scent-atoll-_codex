page {
  background: #f5f5f5;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
}

.hero-desc {
  font-size: 24rpx;
  color: #666666;
  margin-top: 12rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #666666;
}

.button-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.compact-grid button {
  width: 100%;
}

.perfume-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #eeeeee;
}

.perfume-row:last-child {
  border-bottom: none;
}

.perfume-name {
  font-size: 26rpx;
  color: #111111;
}

.perfume-status {
  margin-top: 8rpx;
  font-size: 22rpx;
}
