page {
  background: #f7f3ed;
  color: #221f1c;
}

.storefront {
  padding: 28rpx 28rpx 0;
}

.hero {
  min-height: 430rpx;
  border-radius: 8rpx;
  padding: 36rpx 30rpx;
  background: linear-gradient(135deg, #2b211c 0%, #7a5140 52%, #d8b879 100%);
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  overflow: hidden;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  color: #fffaf2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.eyebrow {
  font-size: 20rpx;
  letter-spacing: 0;
  opacity: 0.76;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 18rpx;
  max-width: 410rpx;
  font-size: 25rpx;
  line-height: 1.58;
  color: rgba(255, 250, 242, 0.82);
}

.hero-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.primary-action,
.secondary-action {
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  white-space: nowrap;
}

.primary-action {
  background: #fffaf2;
  color: #2b211c;
  font-weight: 600;
}

.secondary-action {
  border: 1rpx solid rgba(255, 250, 242, 0.48);
  color: #fffaf2;
}

.hero-product {
  width: 210rpx;
  min-width: 210rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.hero-img {
  width: 210rpx;
  height: 250rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-product-info {
  margin-top: 14rpx;
  color: #fffaf2;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hero-brand {
  font-size: 20rpx;
  opacity: 0.72;
}

.hero-name {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.22;
}

.feature-row {
  margin: 28rpx 0 34rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.feature-card {
  min-height: 126rpx;
  border-radius: 8rpx;
  background: #fffaf4;
  padding: 20rpx 18rpx;
  border: 1rpx solid rgba(72, 55, 42, 0.08);
}

.feature-title {
  font-size: 27rpx;
  font-weight: 650;
}

.feature-desc {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.35;
  color: #8a7667;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8b7a6c;
}

.section-more {
  font-size: 24rpx;
  color: #6f4c35;
  padding-bottom: 5rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  min-height: 220rpx;
  border-radius: 8rpx;
  background: #fffaf4;
  border: 1rpx solid rgba(72, 55, 42, 0.08);
  padding: 18rpx;
  display: flex;
  gap: 20rpx;
}

.product-image-wrap {
  position: relative;
  width: 188rpx;
  min-width: 188rpx;
  height: 188rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #eadfce;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-badge,
.stock-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  border-radius: 4rpx;
  padding: 4rpx 10rpx;
  font-size: 18rpx;
  line-height: 1.2;
}

.product-badge {
  background: #221f1c;
  color: #fffaf4;
}

.stock-badge {
  top: auto;
  bottom: 12rpx;
  background: rgba(255, 250, 244, 0.92);
  color: #8b3328;
}

.product-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.brand {
  font-size: 21rpx;
  color: #8b7a6c;
}

.name {
  margin-top: 6rpx;
  font-size: 31rpx;
  line-height: 1.24;
  font-weight: 650;
}

.desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.42;
  color: #66584d;
}

.tag-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  border-radius: 4rpx;
  background: #f0e5d6;
  color: #6a5748;
  font-size: 20rpx;
  padding: 4rpx 9rpx;
}

.price-row {
  margin-top: auto;
  padding-top: 14rpx;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

.price {
  font-size: 33rpx;
  font-weight: 700;
  color: #261f1b;
}

.origin-price {
  font-size: 22rpx;
  color: #9c8d80;
  text-decoration: line-through;
}

.vip-tag,
.excluded-tag {
  border-radius: 4rpx;
  padding: 3rpx 9rpx;
  font-size: 19rpx;
}

.vip-tag {
  background: #221f1c;
  color: #fffaf4;
}

.excluded-tag {
  background: #eee7dc;
  color: #8b7a6c;
}

.state-card {
  border-radius: 8rpx;
  background: #fffaf4;
  padding: 48rpx 24rpx;
  color: #7b6d61;
  text-align: center;
  font-size: 25rpx;
}

.state-title {
  color: #221f1c;
  font-size: 30rpx;
  font-weight: 650;
}

.state-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
}

.member-band {
  margin-top: 30rpx;
  border-radius: 8rpx;
  background: #221f1c;
  color: #fffaf4;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-title {
  font-size: 32rpx;
  font-weight: 700;
}

.member-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: rgba(255, 250, 244, 0.72);
}

.member-action {
  min-width: 88rpx;
  height: 58rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(255, 250, 244, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.bottom-space {
  height: 40rpx;
}
